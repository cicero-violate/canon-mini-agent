+                    role_schema_bytes: 2,
+                    submit_only: false,
+                }),
+            },
+            crate::tlog::TlogRecord {
+                seq: 2,
+                ts_ms: 3_500,
+                event: Event::effect(EffectEvent::IssuesProjectionRecorded {
+                    path: "agent_state/ISSUES.json".to_string(),
+                    hash: "h".to_string(),
+                    issue_count: 10,
