+        assert!(snapshot.eval_enforcement.passed);
+        assert_eq!(snapshot.eval_enforcement.violation_count, 0);
+        assert!(snapshot.eval_enforcement.warning_count > 0);
+        assert!(snapshot
+            .eval_enforcement
+            .warnings
+            .iter()
+            .any(|w| w.contains("low_confidence_rate=0.4000")));
+    }
