+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn proposal_for_doc(docstring: Option<&str>, path: &str) -> SemanticManifest {
+        let node = GraphNode {
+            path: path.to_string(),
+            kind: "fn".to_string(),
+            signature: Some("fn(&std::path::Path) -> anyhow::Result<()>".to_string()),
+            docstring: docstring.map(str::to_string),
+            ..Default::default()
+        };
+        build_node_semantic_manifest_proposal(
+            "node",
+            &node,
+            Path::new("."),
+            &mut HashMap::new(),
+            &HashMap::new(),
+            &HashMap::new(),
+        )
+    }
+
+    #[test]
+    fn generated_doc_error_placeholders_are_repairable() {
+        let manifest = proposal_for_doc(
+            Some(
+                "Intent: event_append\n\
+                 Resource: error\n\
+                 Inputs: &std::path::Path\n\
+                 Outputs: anyhow::Result<()>\n\
+                 Effects: error\n\
+                 Forbidden: error\n\
+                 Invariants: error\n\
+                 Failure: error\n\
+                 Provenance: rustc:facts + rustc:docstring",
+            ),
+            "tools::append_event_record",
+        );
+
+        assert_eq!(manifest.intent_class, "event_append");
+        assert_ne!(manifest.resource, MISSING);
+        assert!(!contains_missing(&manifest.effects));
+        assert!(!contains_missing(&manifest.forbidden_effects));
+        assert_ne!(manifest.failure_mode, MISSING);
+        assert!(!contains_missing(&manifest.invariants));
+        assert!(!manifest_has_error(&manifest));
+    }
+
+    #[test]
+    fn unknown_low_confidence_is_metric_only_not_partial_error() {
+        let manifest = proposal_for_doc(None, "math::combine_values");
+
+        assert_eq!(manifest.intent_class, UNKNOWN_LOW_CONFIDENCE);
+        assert!(manifest_has_low_confidence(&manifest));
+        assert!(!intent_is_classified(&manifest.intent_class));
+        assert!(!manifest_has_error(&manifest));
+    }
+
+    #[test]
+    fn explicit_hard_doc_error_still_marks_partial_error() {
+        let manifest = proposal_for_doc(
+            Some(
+                "Intent: event_append\n\
+                 Resource: hard_error\n\
+                 Inputs: &std::path::Path\n\
+                 Outputs: anyhow::Result<()>\n\
+                 Effects: fs_write\n\
+                 Forbidden: default_overwrite\n\
+                 Invariants: append_only_log\n\
+                 Failure: fail_closed\n\
+                 Provenance: rustc:facts + rustc:docstring",
+            ),
+            "tools::append_event_record",
+        );
+
+        assert_eq!(manifest.resource, MISSING);
+        assert!(manifest_has_error(&manifest));
